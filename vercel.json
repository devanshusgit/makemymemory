{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "pages/api/**/*": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/**/*": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "INTERNAL_API_SECRET": "@internal_api_secret",
    "ADMIN_PASSWORD": "@admin_password"
  }
}
